<div class="jd-root">

  <!-- ===== TOOLBAR ===== -->
  <div class="jd-toolbar">
    <div class="jd-title">
      <ng-container *ngTemplateOutlet="iconFileJson"></ng-container>
      JSON Compare
    </div>

    <button class="jd-btn" [class.active]="mode === 'diff'" (click)="toggleMode()">
      <ng-container *ngIf="mode === 'diff'"><ng-container *ngTemplateOutlet="iconCheck"></ng-container></ng-container>
      Compare
    </button>

    <ng-container *ngIf="mode === 'edit'">
      <button class="jd-btn" (click)="formatBoth()">Format</button>
      <button class="jd-btn" (click)="resetSample()">
        <ng-container *ngTemplateOutlet="iconReset"></ng-container> Sample
      </button>
    </ng-container>

    <ng-container *ngIf="mode === 'diff'">
      <div class="jd-search-wrap">
        <span class="jd-search-icon"><ng-container *ngTemplateOutlet="iconSearch"></ng-container></span>
        <input
          #searchInput
          placeholder="Search (Ctrl+F)..."
          [(ngModel)]="searchTerm"
          (ngModelChange)="onSearchChange()"
          (keydown)="onSearchKeydown($event)"
        />
      </div>
      <span class="jd-match-count" *ngIf="searchTerm">
        {{ matches.length ? (matchIdx + 1) + '/' + matches.length : '0 found' }}
      </span>
      <ng-container *ngIf="searchTerm && matches.length > 0">
        <button class="jd-btn jd-btn-icon" (click)="gotoMatch(-1)" title="Previous match">
          <ng-container *ngTemplateOutlet="iconChevronUp"></ng-container>
        </button>
        <button class="jd-btn jd-btn-icon" (click)="gotoMatch(1)" title="Next match">
          <ng-container *ngTemplateOutlet="iconChevronDown"></ng-container>
        </button>
      </ng-container>

      <button class="jd-btn" [class.active]="syncScroll" (click)="syncScroll = !syncScroll" title="Keep both panels scrolled together">
        <ng-container *ngTemplateOutlet="syncScroll ? iconLink : iconUnlink"></ng-container> Sync
      </button>
      <button class="jd-btn" (click)="handleCopy()">
        <ng-container *ngTemplateOutlet="copied ? iconCheck : iconCopy"></ng-container> {{ copied ? 'Copied' : 'Copy' }}
      </button>
      <button class="jd-btn" (click)="handleDownload()">
        <ng-container *ngTemplateOutlet="iconDownload"></ng-container> Export
      </button>
    </ng-container>

    <div class="jd-stats" *ngIf="hasDiff">
      <div class="jd-stat jd-stat-total"><b>{{ stats.total }}</b><span>Lines</span></div>
      <div class="jd-stat jd-stat-changed"><b>{{ stats.changed }}</b><span>Changed</span></div>
      <div class="jd-stat jd-stat-added"><b>{{ stats.added }}</b><span>Added</span></div>
      <div class="jd-stat jd-stat-removed"><b>{{ stats.removed }}</b><span>Removed</span></div>
    </div>
  </div>

  <!-- ===== DIFF NAVIGATION BAR ===== -->
  <div class="jd-nav-bar" *ngIf="mode === 'diff' && hasDiff">
    <button class="jd-btn" (click)="gotoHunk(-1)" [disabled]="hunks.length === 0">
      <ng-container *ngTemplateOutlet="iconChevronUp"></ng-container> Prev diff
    </button>
    <button class="jd-btn" (click)="gotoHunk(1)" [disabled]="hunks.length === 0">
      <ng-container *ngTemplateOutlet="iconChevronDown"></ng-container> Next diff
    </button>
    <span class="jd-hunk-count">
      {{ hunks.length ? ('Difference ' + (hunkIdx + 1) + ' of ' + hunks.length) : 'No differences found' }}
    </span>
    <span class="jd-hunk-count" style="margin-left: auto">{{ currentHunkPath }}</span>
  </div>

  <!-- ===== ERROR BAR ===== -->
  <div class="jd-error-bar" *ngIf="(leftError || rightError) && mode === 'diff'">
    <ng-container *ngTemplateOutlet="iconAlert"></ng-container>
    {{ leftError ? ('Left JSON error: ' + leftError) : ('Right JSON error: ' + rightError) }} — switch to Edit mode to fix it.
  </div>

  <!-- ===== MAIN PANES ===== -->
  <div class="jd-panes">

    <!-- LEFT / ORIGINAL -->
    <div class="jd-pane">
      <div class="jd-pane-header">
        <span>Original</span>
        <label class="jd-upload" *ngIf="mode === 'edit'" (click)="triggerUpload('left')">
          <ng-container *ngTemplateOutlet="iconUpload"></ng-container> Upload
        </label>
        <input #leftFile type="file" accept=".json,application/json" style="display:none" (change)="handleFile('left', $event)" />
      </div>

      <textarea *ngIf="mode === 'edit'" spellcheck="false" [(ngModel)]="leftText"></textarea>

      <div class="jd-pane-body" #leftPane (scroll)="onScroll('left')" *ngIf="mode === 'diff'">
        <ng-container *ngIf="hasDiff; else leftNoData">
          <ng-container *ngFor="let row of renderRows; let idx = index; trackBy: trackByIndex">
            <div *ngIf="isCollapsed(row)" class="jd-collapsed-row" [style.height.px]="22" (click)="expandRun(row.id)">
              <span class="jd-collapsed-pill">
                <ng-container *ngTemplateOutlet="iconChevronRight"></ng-container>
                {{ row.count }} unchanged line{{ row.count === 1 ? '' : 's' }}
              </span>
            </div>
            <div *ngIf="!isCollapsed(row)" [class]="rowClass(row, idx, 'left')" [style.height.px]="22">
              <span class="jd-lineno">{{ numOf(row, 'left') }}</span>
              <span class="jd-code">
                <ng-container *ngIf="cellOf(row, 'left') as cell; else blankFill">
                  <span *ngFor="let seg of cell.tokens" [class]="seg.cls">{{ seg.text }}</span>
                </ng-container>
                <ng-template #blankFill><span class="jd-blank-fill">&nbsp;</span></ng-template>
              </span>
            </div>
          </ng-container>
        </ng-container>
        <ng-template #leftNoData>
          <div class="jd-empty-msg">Fix JSON errors to see the comparison.</div>
        </ng-template>
      </div>
    </div>

    <!-- RIGHT / MODIFIED -->
    <div class="jd-pane">
      <div class="jd-pane-header">
        <span>Modified</span>
        <label class="jd-upload" *ngIf="mode === 'edit'" (click)="triggerUpload('right')">
          <ng-container *ngTemplateOutlet="iconUpload"></ng-container> Upload
        </label>
        <input #rightFile type="file" accept=".json,application/json" style="display:none" (change)="handleFile('right', $event)" />
      </div>

      <textarea *ngIf="mode === 'edit'" spellcheck="false" [(ngModel)]="rightText"></textarea>

      <div class="jd-pane-body" #rightPane (scroll)="onScroll('right')" *ngIf="mode === 'diff'">
        <ng-container *ngIf="hasDiff; else rightNoData">
          <ng-container *ngFor="let row of renderRows; let idx = index; trackBy: trackByIndex">
            <div *ngIf="isCollapsed(row)" class="jd-collapsed-row" [style.height.px]="22" (click)="expandRun(row.id)">
              <span class="jd-collapsed-pill">
                <ng-container *ngTemplateOutlet="iconChevronRight"></ng-container>
                {{ row.count }} unchanged line{{ row.count === 1 ? '' : 's' }}
              </span>
            </div>
            <div *ngIf="!isCollapsed(row)" [class]="rowClass(row, idx, 'right')" [style.height.px]="22">
              <span class="jd-lineno">{{ numOf(row, 'right') }}</span>
              <span class="jd-code">
                <ng-container *ngIf="cellOf(row, 'right') as cell; else blankFillR">
                  <span *ngFor="let seg of cell.tokens" [class]="seg.cls">{{ seg.text }}</span>
                </ng-container>
                <ng-template #blankFillR><span class="jd-blank-fill">&nbsp;</span></ng-template>
              </span>
            </div>
          </ng-container>
        </ng-container>
        <ng-template #rightNoData>
          <div class="jd-empty-msg">Fix JSON errors to see the comparison.</div>
        </ng-template>
      </div>
    </div>
  </div>

  <!-- ===== FOOTER ===== -->
  <div class="jd-footer">
    <ng-container *ngIf="mode === 'diff'; else editFooter">
      <span><kbd>n</kbd> / <kbd>p</kbd> next / prev diff</span>
      <span><kbd>Ctrl+F</kbd> search</span>
      <span class="jd-legend"><span class="jd-swatch jd-swatch-removed"></span> removed</span>
      <span class="jd-legend"><span class="jd-swatch jd-swatch-added"></span> added / changed</span>
      <span style="margin-left: auto">Click a collapsed block to expand it</span>
    </ng-container>
    <ng-template #editFooter>
      <span>Paste or upload JSON on each side, then click <b>Compare</b>.</span>
    </ng-template>
  </div>

</div>


:host {
  display: block;
  height: 100%;
}

.jd-root {
  --jd-bg: #ffffff;
  --jd-bg-alt: #f7f8fa;
  --jd-border: #e2e5ea;
  --jd-text: #1f2430;
  --jd-muted: #7c8394;
  --jd-accent: #3b6fe0;
  --jd-accent-soft: #eaf0ff;
  --jd-red-bg: #fdecec;
  --jd-red-border: #f3a9a9;
  --jd-red-text: #b3261e;
  --jd-green-bg: #e9f9ee;
  --jd-green-border: #9bd8ac;
  --jd-green-text: #1b7a3d;
  --jd-key: #a6178f;
  --jd-str: #1a8a5f;
  --jd-num: #b5750a;
  --jd-bool: #2266c9;
  --jd-null: #8a8f9c;
  --jd-brace: #626a7a;

  font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
  background: var(--jd-bg);
  color: var(--jd-text);
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 640px;
  border: 1px solid var(--jd-border);
  border-radius: 10px;
  overflow: hidden;
}

/* ---------- icons ---------- */
.jd-icon {
  width: 14px;
  height: 14px;
  flex-shrink: 0;
  fill: none;
  stroke: currentColor;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
  vertical-align: -2px;
}
.jd-title .jd-icon { width: 16px; height: 16px; }

/* ---------- toolbar ---------- */
.jd-toolbar {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  border-bottom: 1px solid var(--jd-border);
  background: var(--jd-bg-alt);
  flex-wrap: wrap;
}
.jd-title { display: flex; align-items: center; gap: 8px; font-weight: 600; font-size: 13.5px; color: var(--jd-text); margin-right: 6px; }
.jd-btn {
  display: inline-flex; align-items: center; gap: 6px;
  border: 1px solid var(--jd-border); background: var(--jd-bg);
  color: var(--jd-text); font-size: 12.5px; font-weight: 500;
  padding: 6px 10px; border-radius: 6px; cursor: pointer;
  transition: background .12s, border-color .12s;
}
.jd-btn:hover { background: var(--jd-bg-alt); border-color: #c9cedb; }
.jd-btn:disabled { opacity: .4; cursor: not-allowed; }
.jd-btn.active { background: var(--jd-accent); border-color: var(--jd-accent); color: #fff; }
.jd-btn-icon { padding: 6px; }

.jd-search-wrap { position: relative; flex: 1; min-width: 180px; max-width: 320px; }
.jd-search-wrap input {
  width: 100%; padding: 6px 10px 6px 30px; border: 1px solid var(--jd-border);
  border-radius: 6px; font-size: 12.5px; background: var(--jd-bg); color: var(--jd-text);
  box-sizing: border-box;
}
.jd-search-wrap input:focus { outline: 2px solid var(--jd-accent-soft); border-color: var(--jd-accent); }
.jd-search-icon { position: absolute; left: 9px; top: 50%; transform: translateY(-50%); color: var(--jd-muted); display: flex; }
.jd-match-count { font-size: 11.5px; color: var(--jd-muted); white-space: nowrap; }

.jd-stats { display: flex; gap: 6px; margin-left: auto; }
.jd-stat { display: flex; flex-direction: column; align-items: center; padding: 4px 10px; border-radius: 6px; min-width: 52px; }
.jd-stat b { font-size: 15px; line-height: 1.1; }
.jd-stat span { font-size: 9.5px; color: var(--jd-muted); text-transform: uppercase; letter-spacing: .04em; }
.jd-stat-changed { background: #fff6e6; } .jd-stat-changed b { color: #b5750a; }
.jd-stat-added { background: var(--jd-green-bg); } .jd-stat-added b { color: var(--jd-green-text); }
.jd-stat-removed { background: var(--jd-red-bg); } .jd-stat-removed b { color: var(--jd-red-text); }
.jd-stat-total { background: var(--jd-accent-soft); } .jd-stat-total b { color: var(--jd-accent); }

/* ---------- diff nav bar ---------- */
.jd-nav-bar {
  display: flex; align-items: center; gap: 8px; padding: 6px 14px;
  border-bottom: 1px solid var(--jd-border); background: var(--jd-bg); font-size: 12px;
}
.jd-nav-bar .jd-btn { padding: 4px 8px; }
.jd-hunk-count { color: var(--jd-muted); font-variant-numeric: tabular-nums; }

/* ---------- error bar ---------- */
.jd-error-bar {
  padding: 8px 14px; background: var(--jd-red-bg); color: var(--jd-red-text); font-size: 12.5px;
  display: flex; gap: 6px; align-items: center; border-bottom: 1px solid var(--jd-red-border);
}

/* ---------- panes ---------- */
.jd-panes { flex: 1; display: flex; overflow: hidden; min-height: 0; }
.jd-pane { flex: 1; display: flex; flex-direction: column; min-width: 0; }
.jd-pane + .jd-pane { border-left: 1px solid var(--jd-border); }
.jd-pane-header {
  padding: 8px 14px; font-size: 12px; font-weight: 600; color: var(--jd-muted);
  background: var(--jd-bg-alt); border-bottom: 1px solid var(--jd-border);
  display: flex; justify-content: space-between; align-items: center;
}
.jd-pane-header label.jd-upload { cursor: pointer; color: var(--jd-accent); display: inline-flex; align-items: center; gap: 4px; font-weight: 500; }
.jd-pane-body { flex: 1; overflow: auto; font-family: "SF Mono", ui-monospace, Menlo, Consolas, monospace; font-size: 12.5px; }
.jd-pane textarea {
  flex: 1; width: 100%; border: none; resize: none; padding: 12px 14px; box-sizing: border-box;
  font-family: "SF Mono", ui-monospace, Menlo, Consolas, monospace; font-size: 12.5px;
  background: var(--jd-bg); color: var(--jd-text); outline: none; line-height: 1.6;
}
.jd-empty-msg { padding: 16px; color: var(--jd-muted); font-size: 12.5px; font-family: ui-sans-serif, system-ui, sans-serif; }

/* ---------- rows ---------- */
.jd-row { display: flex; align-items: center; white-space: pre; cursor: default; width: max-content; min-width: 100%; }
.jd-lineno { width: 44px; flex-shrink: 0; text-align: right; padding-right: 10px; color: var(--jd-muted); font-size: 11px; user-select: none; }
.jd-code { flex: 0 0 auto; padding-right: 24px; }
.jd-row-equal:hover { background: var(--jd-bg-alt); }
.jd-row-removed { background: var(--jd-red-bg); border-left: 3px solid var(--jd-red-border); }
.jd-row-removed .jd-lineno { color: var(--jd-red-text); }
.jd-row-added { background: var(--jd-green-bg); border-left: 3px solid var(--jd-green-border); }
.jd-row-added .jd-lineno { color: var(--jd-green-text); }
.jd-row-blank { background: repeating-linear-gradient(135deg, var(--jd-bg-alt), var(--jd-bg-alt) 4px, #eef0f4 4px, #eef0f4 8px); border-left: 3px solid transparent; }
.jd-row-hunk-active { box-shadow: inset 0 0 0 2px var(--jd-accent); }
.jd-row-match-active { box-shadow: inset 0 0 0 2px #d99a1e; }
.jd-blank-fill { opacity: 0; }

.jd-collapsed-row { display: flex; align-items: center; justify-content: center; background: var(--jd-bg-alt); cursor: pointer; border-top: 1px dashed var(--jd-border); border-bottom: 1px dashed var(--jd-border); }
.jd-collapsed-row:hover .jd-collapsed-pill { background: var(--jd-accent); color: #fff; }
.jd-collapsed-pill { display: inline-flex; align-items: center; gap: 4px; font-size: 10.5px; color: var(--jd-muted); background: var(--jd-bg); border: 1px solid var(--jd-border); border-radius: 999px; padding: 1px 9px; transition: background .12s, color .12s; }
.jd-collapsed-pill .jd-icon { width: 11px; height: 11px; }

/* ---------- json syntax colors ---------- */
.jd-code .jd-key { color: var(--jd-key); }
.jd-code .jd-str { color: var(--jd-str); }
.jd-code .jd-num { color: var(--jd-num); }
.jd-code .jd-bool { color: var(--jd-bool); font-weight: 600; }
.jd-code .jd-null { color: var(--jd-null); font-style: italic; }
.jd-code .jd-brace { color: var(--jd-brace); }

/* ---------- footer ---------- */
.jd-footer { display: flex; align-items: center; gap: 18px; padding: 7px 14px; border-top: 1px solid var(--jd-border); background: var(--jd-bg-alt); font-size: 11px; color: var(--jd-muted); }
.jd-footer kbd { background: #fff; border: 1px solid var(--jd-border); border-radius: 4px; padding: 1px 6px; font-family: inherit; color: var(--jd-text); }
.jd-legend { display: flex; align-items: center; gap: 5px; }
.jd-swatch { width: 10px; height: 10px; border-radius: 2px; display: inline-block; }
.jd-swatch-removed { background: var(--jd-red-bg); border: 1px solid var(--jd-red-border); }
.jd-swatch-added { background: var(--jd-green-bg); border: 1px solid var(--jd-green-border); }

/* ---------- scrollbars ---------- */
.jd-pane-body::-webkit-scrollbar, .jd-pane textarea::-webkit-scrollbar { width: 10px; height: 10px; }
.jd-pane-body::-webkit-scrollbar-thumb { background: #d3d7e0; border-radius: 6px; border: 2px solid var(--jd-bg); }
.jd-pane-body::-webkit-scrollbar-track { background: transparent; }




