import {
  Directive,
  ElementRef,
  EventEmitter,
  Input,
  Output,
  OnInit,
  OnDestroy,
  NgZone,
  ChangeDetectorRef
} from '@angular/core';
import { Subject } from 'rxjs';
import { debounceTime, takeUntil } from 'rxjs/operators';

export interface VirtualScrollEvent {
  startIndex: number;
  endIndex: number;
  scrollOffset: number;
  scrollPercentage: number;
}

/**
 * Virtual scroll directive for efficient rendering of large lists
 * Renders only visible rows to improve performance significantly
 * 
 * Usage:
 * <div appVirtualScroll [items]="items" [itemHeight]="22" (scrolled)="onScroll($event)">
 *   <div *ngFor="let item of visibleItems">{{ item }}</div>
 * </div>
 */
@Directive({
  selector: '[appVirtualScroll]',
  standalone: true
})
export class VirtualScrollDirective implements OnInit, OnDestroy {
  @Input() items: any[] = [];
  @Input() itemHeight: number = 22; // Fixed row height in pixels
  @Input() bufferSize: number = 5; // Extra rows to render outside viewport
  @Input() debounceTime: number = 16; // Debounce scroll events (roughly 60fps)

  @Output() scrolled = new EventEmitter<VirtualScrollEvent>();
  @Output() visibleItemsChanged = new EventEmitter<any[]>();

  // Visible items
  visibleItems: any[] = [];
  visibleItemsSet: Set<any> = new Set();

  private destroy$ = new Subject<void>();
  private scrollSubject = new Subject<Event>();
  private containerHeight = 0;
  private scrollTop = 0;
  private totalHeight = 0;

  constructor(
    private el: ElementRef,
    private ngZone: NgZone,
    private cdr: ChangeDetectorRef
  ) {}

  ngOnInit(): void {
    // Get container element
    const container = this.el.nativeElement as HTMLElement;

    // Set up scroll listener outside Angular zone for performance
    this.ngZone.runOutsideAngular(() => {
      container.addEventListener('scroll', (event) => {
        this.scrollSubject.next(event);
      });

      // Debounced scroll handler
      this.scrollSubject
        .pipe(
          debounceTime(this.debounceTime),
          takeUntil(this.destroy$)
        )
        .subscribe(() => {
          this.onScroll();
        });
    });

    // Initial calculation
    this.updateContainerHeight();
    this.updateVisibleItems();

    // Handle resize
    window.addEventListener('resize', () => this.updateContainerHeight());
  }

  ngOnDestroy(): void {
    this.destroy$.next();
    this.destroy$.complete();
  }

  /**
   * Update container height
   */
  private updateContainerHeight(): void {
    const container = this.el.nativeElement as HTMLElement;
    this.containerHeight = container.clientHeight;
    this.totalHeight = this.items.length * this.itemHeight;
    this.updateVisibleItems();
  }

  /**
   * Handle scroll event
   */
  private onScroll(): void {
    const container = this.el.nativeElement as HTMLElement;
    this.scrollTop = container.scrollTop;
    this.updateVisibleItems();
  }

  /**
   * Update visible items based on scroll position
   */
  private updateVisibleItems(): void {
    if (!this.items.length || !this.containerHeight) {
      this.visibleItems = [];
      this.visibleItemsSet.clear();
      return;
    }

    // Calculate visible range
    let startIndex = Math.max(0, Math.floor(this.scrollTop / this.itemHeight) - this.bufferSize);
    let endIndex = Math.min(
      this.items.length,
      Math.ceil((this.scrollTop + this.containerHeight) / this.itemHeight) + this.bufferSize
    );

    // Update visible items
    const newVisibleItems = this.items.slice(startIndex, endIndex);
    
    // Only update if changed (avoid unnecessary change detection)
    if (newVisibleItems.length !== this.visibleItems.length ||
        !newVisibleItems.every((item, i) => item === this.visibleItems[i])) {
      
      this.ngZone.run(() => {
        this.visibleItems = newVisibleItems;
        this.visibleItemsSet.clear();
        newVisibleItems.forEach(item => this.visibleItemsSet.add(item));
        this.cdr.markForCheck();
        this.visibleItemsChanged.emit(newVisibleItems);
      });
    }

    // Emit scroll event
    const scrollPercentage = this.scrollTop / (this.totalHeight - this.containerHeight);
    this.scrolled.emit({
      startIndex,
      endIndex,
      scrollOffset: this.scrollTop,
      scrollPercentage: Math.max(0, Math.min(1, scrollPercentage))
    });
  }

  /**
   * Scroll to a specific index
   */
  scrollToIndex(index: number, smooth = true): void {
    const container = this.el.nativeElement as HTMLElement;
    const targetScrollTop = index * this.itemHeight;

    if (smooth) {
      container.scrollTo({
        top: targetScrollTop,
        behavior: 'smooth'
      });
    } else {
      container.scrollTop = targetScrollTop;
    }
  }

  /**
   * Scroll to a specific item
   */
  scrollToItem(item: any, smooth = true): void {
    const index = this.items.indexOf(item);
    if (index !== -1) {
      this.scrollToIndex(index, smooth);
    }
  }

  /**
   * Check if item is visible
   */
  isItemVisible(item: any): boolean {
    return this.visibleItemsSet.has(item);
  }

  /**
   * Get content height for spacer
   */
  getContentHeight(): number {
    return this.totalHeight;
  }

  /**
   * Get offset height for spacer
   */
  getOffsetHeight(): number {
    const container = this.el.nativeElement as HTMLElement;
    const topIndex = Math.floor(this.scrollTop / this.itemHeight);
    return topIndex * this.itemHeight;
  }
}
