import {
  Component,
  ElementRef,
  HostListener,
  OnInit,
  ViewChild
} from '@angular/core';
import { CommonModule } from '@angular/common';
import { FormsModule } from '@angular/forms';

/* ============================================================================
   TYPES
   ========================================================================== */

interface Token {
  text: string;
  cls: string | null;
}

interface JsonLine {
  text: string;
  path: (string | number)[];
  depth: number;
  tokens: Token[];
}

type RowType = 'equal' | 'changed' | 'added' | 'removed';

interface DiffRow {
  type: RowType;
  left: JsonLine | null;
  right: JsonLine | null;
  leftNum: number | null;
  rightNum: number | null;
}

interface CollapsedRow {
  type: 'collapsed';
  id: string;
  count: number;
}

type RenderRow = DiffRow | CollapsedRow;

interface DiffOp {
  type: 'equal' | 'insert' | 'delete';
  aIndex: number;
  bIndex: number;
}

interface Stats {
  changed: number;
  added: number;
  removed: number;
  unchanged: number;
  total: number;
}

/* ============================================================================
   COMPONENT
   ========================================================================== */

@Component({
  selector: 'app-json-diff-viewer',
  standalone: true,
  imports: [CommonModule, FormsModule],
  templateUrl: './json-diff-viewer.component.html',
  styleUrls: ['./json-diff-viewer.component.css']
})
export class JsonDiffViewerComponent implements OnInit {
  private readonly ROW_H = 22;              // fixed row height in px -> O(1) scroll math
  private readonly COLLAPSE_AFTER = 6;      // collapse equal-runs longer than this
  private readonly CONTEXT_LINES = 2;       // lines of context kept around a collapsed run

  /* ---------------- state ---------------- */
  leftText = '';
  rightText = '';
  mode: 'edit' | 'diff' = 'diff';
  leftError: string | null = null;
  rightError: string | null = null;

  syncScroll = true;
  searchTerm = '';
  hunkIdx = 0;
  matchIdx = 0;
  expandedRuns = new Set<string>();
  copied = false;

  rows: DiffRow[] = [];
  renderRows: RenderRow[] = [];
  hunks: number[] = [];
  matches: number[] = [];
  stats: Stats = { changed: 0, added: 0, removed: 0, unchanged: 0, total: 0 };
  hasDiff = false;

  @ViewChild('leftPane') leftPaneRef?: ElementRef<HTMLDivElement>;
  @ViewChild('rightPane') rightPaneRef?: ElementRef<HTMLDivElement>;
  @ViewChild('searchInput') searchInputRef?: ElementRef<HTMLInputElement>;
  @ViewChild('leftFile') leftFileRef?: ElementRef<HTMLInputElement>;
  @ViewChild('rightFile') rightFileRef?: ElementRef<HTMLInputElement>;

  private scrollingSide: 'left' | 'right' | null = null;

  private readonly sampleLeft = {
    'Aidan Gillen': {
      array: ['Game of Thrones', 'The Wire'],
      string: 'some string',
      int: '2',
      otherint: 4,
      aboolean: 'true',
      booleean: false,
      null: null,
      a_null: 88,
      another_null: null,
      object: { foo: 'bar' }
    },
    'Amy Ryan': ['In Treatment', 'The Wire'],
    'Annie Fitzgerald': ['True Blood', 'Big Love', 'The Sopranos', 'Oz']
  };

  private readonly sampleRight = {
    'Aidan Gillen': {
      array: ['Game of Thrones', 'The Wire'],
      string: 'some string',
      int: 2,
      aboolean: true,
      booleean: true,
      null: null,
      a_null: null,
      another_null: 'null check',
      object: { foo: 'bar', object1: { new_prop1: 'new prop value' } }
    },
    'Amy Ryan': ['In Treatment', 'The Wire'],
    'Annie Fitzgerald': ['True Blood', 'Big Love', 'The Sopranos'],
    'Carol Chen': { array: ['Person of Interest'] }
  };

  ngOnInit(): void {
    this.resetSample();
    this.recomputeDiff();
  }

  /* ============================================================================
     PIPELINE: parse -> diff -> rows -> collapse -> hunks/matches/stats
     ========================================================================== */

  toggleMode(): void {
    this.mode = this.mode === 'diff' ? 'edit' : 'diff';
    if (this.mode === 'diff') this.recomputeDiff();
  }

  recomputeDiff(): void {
    let leftParsed: unknown = undefined;
    let rightParsed: unknown = undefined;

    try {
      leftParsed = JSON.parse(this.leftText);
      this.leftError = null;
    } catch (e) {
      this.leftError = (e as Error).message;
    }
    try {
      rightParsed = JSON.parse(this.rightText);
      this.rightError = null;
    } catch (e) {
      this.rightError = (e as Error).message;
    }

    this.hasDiff = !this.leftError && !this.rightError;

    if (!this.hasDiff) {
      this.rows = [];
      this.renderRows = [];
      this.hunks = [];
      this.matches = [];
      this.stats = { changed: 0, added: 0, removed: 0, unchanged: 0, total: 0 };
      return;
    }

    const leftLines = this.jsonToLines(leftParsed);
    const rightLines = this.jsonToLines(rightParsed);
    const ops = this.myersDiff(
      leftLines.map(l => l.text),
      rightLines.map(l => l.text)
    );
    this.rows = this.buildRows(ops, leftLines, rightLines);
    this.expandedRuns = new Set();
    this.hunkIdx = 0;
    this.matchIdx = 0;
    this.updateRenderRows();
    this.updateStats();
    this.updateMatches();
  }

  private updateRenderRows(): void {
    this.renderRows = this.collapseRows(this.rows, this.expandedRuns);
    this.updateHunks();
  }

  private updateHunks(): void {
    const list: number[] = [];
    let inHunk = false;
    this.renderRows.forEach((r, i) => {
      const isDiff = r.type === 'changed' || r.type === 'added' || r.type === 'removed';
      if (isDiff && !inHunk) {
        list.push(i);
        inHunk = true;
      } else if (!isDiff) {
        inHunk = false;
      }
    });
    this.hunks = list;
    if (this.hunkIdx >= list.length) this.hunkIdx = 0;
  }

  private updateStats(): void {
    let changed = 0, added = 0, removed = 0, unchanged = 0;
    this.rows.forEach(r => {
      if (r.type === 'changed') changed++;
      else if (r.type === 'added') added++;
      else if (r.type === 'removed') removed++;
      else unchanged++;
    });
    this.stats = { changed, added, removed, unchanged, total: this.rows.length };
  }

  onSearchChange(): void {
    this.updateMatches();
  }

  private updateMatches(): void {
    if (!this.searchTerm.trim()) {
      this.matches = [];
      this.matchIdx = 0;
      return;
    }
    const term = this.searchTerm.toLowerCase();
    const list: number[] = [];
    this.renderRows.forEach((r, i) => {
      if (r.type === 'collapsed') return;
      const l = r.left?.text?.toLowerCase() || '';
      const rt = r.right?.text?.toLowerCase() || '';
      if (l.includes(term) || rt.includes(term)) list.push(i);
    });
    this.matches = list;
    this.matchIdx = 0;
  }

  /* ============================================================================
     DIFF ENGINE (pure logic)
     ========================================================================== */

  private tokenizeLine(text: string): Token[] {
    const tokens: Token[] = [];
    const regex = /("(?:[^"\\]|\\.)*")(\s*:)|("(?:[^"\\]|\\.)*")|(-?\d+\.?\d*)|(true|false)|(null)|([{}[\]])/g;
    let lastIndex = 0;
    let m: RegExpExecArray | null;

    while ((m = regex.exec(text)) !== null) {
      if (m.index > lastIndex) {
        tokens.push({ text: text.slice(lastIndex, m.index), cls: null });
      }
      if (m[1] !== undefined) {
        tokens.push({ text: m[1], cls: 'jd-key' });
        tokens.push({ text: m[2], cls: null });
      } else if (m[3] !== undefined) {
        tokens.push({ text: m[3], cls: 'jd-str' });
      } else if (m[4] !== undefined) {
        tokens.push({ text: m[4], cls: 'jd-num' });
      } else if (m[5] !== undefined) {
        tokens.push({ text: m[5], cls: 'jd-bool' });
      } else if (m[6] !== undefined) {
        tokens.push({ text: m[6], cls: 'jd-null' });
      } else if (m[7] !== undefined) {
        const isClosing = m[7] === '}' || m[7] === ']';
        const beforeIsWhitespace = /^\s*$/.test(text.slice(0, m.index));
        tokens.push({ text: m[7], cls: isClosing && beforeIsWhitespace ? 'jd-brace' : null });
      }
      lastIndex = regex.lastIndex;
    }
    if (lastIndex < text.length) {
      tokens.push({ text: text.slice(lastIndex), cls: null });
    }
    return tokens;
  }

  // Recursively turn a JSON value into an array of {text, path, depth, tokens}
  // lines, formatted exactly like JSON.stringify(value, null, 2).
  private jsonToLines(value: unknown): JsonLine[] {
    const lines: JsonLine[] = [];
    const push = (text: string, path: (string | number)[], depth: number) => {
      lines.push({ text, path, depth, tokens: this.tokenizeLine(text) });
    };

    const walk = (
      val: any,
      depth: number,
      path: (string | number)[],
      isLast: boolean,
      key: string | number | undefined
    ): void => {
      const indent = '  '.repeat(depth);
      const keyStr = key !== undefined ? `"${key}": ` : '';
      const comma = isLast ? '' : ',';

      if (val === null || typeof val !== 'object') {
        push(`${indent}${keyStr}${JSON.stringify(val)}${comma}`, path, depth);
        return;
      }
      const isArray = Array.isArray(val);
      const entries: [string | number, any][] = isArray
        ? val.map((v: any, i: number) => [i, v])
        : Object.entries(val);

      if (entries.length === 0) {
        push(`${indent}${keyStr}${isArray ? '[]' : '{}'}${comma}`, path, depth);
        return;
      }

      push(`${indent}${keyStr}${isArray ? '[' : '{'}`, path, depth);
      entries.forEach(([k, v], idx) => {
        const childIsLast = idx === entries.length - 1;
        const childPath = [...path, k];
        walk(v, depth + 1, childPath, childIsLast, isArray ? undefined : k);
      });
      push(`${indent}${isArray ? ']' : '}'}${comma}`, path, depth);
    };

    walk(value, 0, [], true, undefined);
    return lines;
  }

  // Myers O(ND) diff over two arrays of strings.
  private myersDiff(a: string[], b: string[]): DiffOp[] {
    const N = a.length, M = b.length;
    const MAX = N + M || 1;
    const v: Record<number, number> = { 1: 0 };
    const trace: Record<number, number>[] = [];

    const backtrack = (trace: Record<number, number>[], N: number, M: number): DiffOp[] => {
      let x = N, y = M;
      const ops: DiffOp[] = [];
      for (let d = trace.length - 1; d >= 0; d--) {
        const vv = trace[d];
        const k = x - y;
        const prevK = (k === -d || (k !== d && vv[k - 1] < vv[k + 1])) ? k + 1 : k - 1;
        const prevX = vv[prevK];
        const prevY = prevX - prevK;
        while (x > prevX && y > prevY) {
          ops.push({ type: 'equal', aIndex: x - 1, bIndex: y - 1 });
          x--; y--;
        }
        if (d > 0) {
          if (x === prevX) ops.push({ type: 'insert', aIndex: -1, bIndex: prevY });
          else ops.push({ type: 'delete', aIndex: prevX, bIndex: -1 });
        }
        x = prevX; y = prevY;
      }
      return ops.reverse();
    };

    for (let d = 0; d <= MAX; d++) {
      trace.push({ ...v });
      for (let k = -d; k <= d; k += 2) {
        let x: number;
        if (k === -d || (k !== d && v[k - 1] < v[k + 1])) x = v[k + 1];
        else x = v[k - 1] + 1;
        let y = x - k;
        while (x < N && y < M && a[x] === b[y]) { x++; y++; }
        v[k] = x;
        if (x >= N && y >= M) return backtrack(trace, N, M);
      }
    }
    return backtrack(trace, N, M);
  }

  // Turn the flat op list into aligned rows. 'changed' rows pair a delete+
  // insert at the same position; leftovers become 'removed'/'added' rows.
  private buildRows(ops: DiffOp[], leftLines: JsonLine[], rightLines: JsonLine[]): DiffRow[] {
    const rows: DiffRow[] = [];
    let delBuf: DiffOp[] = [];
    let insBuf: DiffOp[] = [];

    const flush = () => {
      const pairCount = Math.min(delBuf.length, insBuf.length);
      for (let i = 0; i < pairCount; i++) {
        rows.push({
          type: 'changed',
          left: leftLines[delBuf[i].aIndex],
          right: rightLines[insBuf[i].bIndex],
          leftNum: null, rightNum: null
        });
      }
      for (let i = pairCount; i < delBuf.length; i++) {
        rows.push({ type: 'removed', left: leftLines[delBuf[i].aIndex], right: null, leftNum: null, rightNum: null });
      }
      for (let i = pairCount; i < insBuf.length; i++) {
        rows.push({ type: 'added', left: null, right: rightLines[insBuf[i].bIndex], leftNum: null, rightNum: null });
      }
      delBuf = []; insBuf = [];
    };

    for (const op of ops) {
      if (op.type === 'equal') {
        flush();
        rows.push({
          type: 'equal',
          left: leftLines[op.aIndex],
          right: rightLines[op.bIndex],
          leftNum: null, rightNum: null
        });
      } else if (op.type === 'delete') {
        delBuf.push(op);
      } else {
        insBuf.push(op);
      }
    }
    flush();

    let ln = 0, rn = 0;
    for (const row of rows) {
      row.leftNum = row.left ? ++ln : null;
      row.rightNum = row.right ? ++rn : null;
    }
    return rows;
  }

  // Collapse long equal-runs into a single marker row (unless expanded).
  private collapseRows(rows: DiffRow[], expandedRuns: Set<string>): RenderRow[] {
    const out: RenderRow[] = [];
    let i = 0;
    while (i < rows.length) {
      if (rows[i].type === 'equal') {
        let j = i;
        while (j < rows.length && rows[j].type === 'equal') j++;
        const runLen = j - i;
        const id = `run-${i}`;
        if (runLen > this.COLLAPSE_AFTER && !expandedRuns.has(id)) {
          for (let c = 0; c < this.CONTEXT_LINES; c++) out.push(rows[i + c]);
          out.push({ type: 'collapsed', id, count: runLen - this.CONTEXT_LINES * 2 });
          for (let c = runLen - this.CONTEXT_LINES; c < runLen; c++) out.push(rows[i + c]);
        } else {
          for (let c = i; c < j; c++) out.push(rows[c]);
        }
        i = j;
      } else {
        out.push(rows[i]);
        i++;
      }
    }
    return out;
  }

  /* ============================================================================
     UI HELPERS
     ========================================================================== */

  isCollapsed(row: RenderRow): row is CollapsedRow {
    return row.type === 'collapsed';
  }

  trackByIndex(index: number): number {
    return index;
  }

  rowClass(row: RenderRow, idx: number, side: 'left' | 'right'): string {
    if (row.type === 'collapsed') return '';
    const r = row as DiffRow;
    let cls = 'jd-row';
    if (r.type === 'equal') cls += ' jd-row-equal';
    if (r.type === 'changed') cls += side === 'left' ? ' jd-row-removed jd-row-changed' : ' jd-row-added jd-row-changed';
    if (r.type === 'removed') cls += side === 'left' ? ' jd-row-removed' : ' jd-row-blank';
    if (r.type === 'added') cls += side === 'right' ? ' jd-row-added' : ' jd-row-blank';
    if (this.hunks[this.hunkIdx] === idx && r.type !== 'equal') cls += ' jd-row-hunk-active';
    if (this.matches[this.matchIdx] === idx) cls += ' jd-row-match-active';
    return cls;
  }

  cellOf(row: RenderRow, side: 'left' | 'right'): JsonLine | null {
    if (row.type === 'collapsed') return null;
    const r = row as DiffRow;
    return side === 'left' ? r.left : r.right;
  }

  numOf(row: RenderRow, side: 'left' | 'right'): number | null {
    if (row.type === 'collapsed') return null;
    const r = row as DiffRow;
    return side === 'left' ? r.leftNum : r.rightNum;
  }

  expandRun(id: string): void {
    this.expandedRuns.add(id);
    this.updateRenderRows();
  }

  get currentHunkPath(): string {
    const row = this.renderRows[this.hunks[this.hunkIdx]];
    if (!row || row.type === 'collapsed') return '';
    const r = row as DiffRow;
    const path = (r.left || r.right)?.path;
    return path && path.length ? path.join(' \u203a ') : 'root';
  }

  /* ============================================================================
     NAVIGATION & SCROLL SYNC
     ========================================================================== */

  private scrollBothTo(rowIndex: number): void {
    const target = Math.max(0, rowIndex * this.ROW_H - 60);
    if (this.leftPaneRef) this.leftPaneRef.nativeElement.scrollTop = target;
    if (this.rightPaneRef) this.rightPaneRef.nativeElement.scrollTop = target;
  }

  gotoHunk(dir: number): void {
    if (this.hunks.length === 0) return;
    this.hunkIdx = (this.hunkIdx + dir + this.hunks.length) % this.hunks.length;
    this.scrollBothTo(this.hunks[this.hunkIdx]);
  }

  gotoMatch(dir: number): void {
    if (this.matches.length === 0) return;
    this.matchIdx = (this.matchIdx + dir + this.matches.length) % this.matches.length;
    this.scrollBothTo(this.matches[this.matchIdx]);
  }

  onSearchKeydown(e: KeyboardEvent): void {
    if (e.key === 'Enter') this.gotoMatch(e.shiftKey ? -1 : 1);
  }

  onScroll(side: 'left' | 'right'): void {
    if (!this.syncScroll) return;
    if (this.scrollingSide && this.scrollingSide !== side) return;
    this.scrollingSide = side;
    const source = side === 'left' ? this.leftPaneRef : this.rightPaneRef;
    const target = side === 'left' ? this.rightPaneRef : this.leftPaneRef;
    if (source && target) target.nativeElement.scrollTop = source.nativeElement.scrollTop;
    requestAnimationFrame(() => { this.scrollingSide = null; });
  }

  @HostListener('window:keydown', ['$event'])
  handleGlobalKeydown(e: KeyboardEvent): void {
    const target = e.target as HTMLElement;
    const typing = target && (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA');
    if ((e.ctrlKey || e.metaKey) && e.key === 'f') {
      e.preventDefault();
      this.searchInputRef?.nativeElement.focus();
    } else if (this.mode === 'diff' && !e.ctrlKey && !e.metaKey && !typing) {
      if (e.key === 'n') this.gotoHunk(1);
      if (e.key === 'p') this.gotoHunk(-1);
    }
  }

  /* ============================================================================
     FILE / EXPORT / MISC ACTIONS
     ========================================================================== */

  triggerUpload(side: 'left' | 'right'): void {
    const ref = side === 'left' ? this.leftFileRef : this.rightFileRef;
    ref?.nativeElement.click();
  }

  handleFile(side: 'left' | 'right', event: Event): void {
    const input = event.target as HTMLInputElement;
    const file = input.files?.[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (ev) => {
      const text = String(ev.target?.result ?? '');
      try {
        const parsed = JSON.parse(text);
        const pretty = JSON.stringify(parsed, null, 2);
        if (side === 'left') this.leftText = pretty; else this.rightText = pretty;
      } catch {
        if (side === 'left') this.leftText = text; else this.rightText = text;
      }
    };
    reader.readAsText(file);
    input.value = '';
  }

  async handleCopy(): Promise<void> {
    try {
      await navigator.clipboard.writeText(this.rightText);
      this.copied = true;
      setTimeout(() => (this.copied = false), 1500);
    } catch {
      /* clipboard unavailable */
    }
  }

  handleDownload(): void {
    const report = this.renderRows
      .filter((r): r is DiffRow => r.type !== 'equal' && r.type !== 'collapsed')
      .map(r => {
        if (r.type === 'changed') return `~ ${r.left!.text.trim()}  ->  ${r.right!.text.trim()}`;
        if (r.type === 'removed') return `- ${r.left!.text.trim()}`;
        return `+ ${r.right!.text.trim()}`;
      })
      .join('\n');
    const blob = new Blob([report], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'json-diff-report.txt';
    a.click();
    URL.revokeObjectURL(url);
  }

  formatBoth(): void {
    try { this.leftText = JSON.stringify(JSON.parse(this.leftText), null, 2); } catch { /* keep as-is */ }
    try { this.rightText = JSON.stringify(JSON.parse(this.rightText), null, 2); } catch { /* keep as-is */ }
  }

  resetSample(): void {
    this.leftText = JSON.stringify(this.sampleLeft, null, 2);
    this.rightText = JSON.stringify(this.sampleRight, null, 2);
  }
}




